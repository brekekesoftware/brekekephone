<selector xmlns:android="http://schemas.android.com/apk/res/android">
  <item android:state_pressed="true">
    <layer-list>
      <shape>
        <solid android:color="#0A808080" />
      </shape>
      <item
        android:bottom="5dp"
        android:drawable="@drawable/ic_chat"
        android:left="5dp"
        android:right="5dp"
        android:top="5dp"
      />
    </layer-list>
  </item>
  <item android:state_pressed="false">
    <layer-list>
      <item
        android:bottom="5dp"
        android:drawable="@drawable/ic_chat"
        android:left="5dp"
        android:right="5dp"
        android:top="5dp"
      />
    </layer-list>
  </item>
</selector>

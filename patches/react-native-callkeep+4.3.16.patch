+@implementation RNCallKeep
+{
+    NSOperatingSystemVersion _version;
+    BOOL _isStartCallActionEventListenerAdded;
+    bool _hasListeners;
+    bool _isReachable;
+    NSMutableArray *_delayedEvents;

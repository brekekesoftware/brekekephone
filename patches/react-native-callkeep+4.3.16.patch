+    private String getSelectedAudioRoute(AudioManager audioManager){
+        if(audioManager.isBluetoothScoOn()){
+            return "Bluetooth";
+        }
+        if(audioManager.isSpeakerphoneOn()){
+            return "Speaker";
+        }
+        if(audioManager.isWiredHeadsetOn()){
+            return "Headset";
+        }
+        return "Phone";
+    }
